{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Android: Start Emulator (Pixel_6a)",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "command": "\"C:\\Users\\Administrator\\AppData\\Local\\Android\\Sdk\\emulator\\emulator.exe\" -avd Pixel_6a -no-snapshot-load"
    },
    {
      "name": "Android: Relaunch App On Emulator",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "command": "\"C:\\Users\\Administrator\\AppData\\Local\\Android\\Sdk\\platform-tools\\adb.exe\" shell am force-stop com.bof.mobile && \"C:\\Users\\Administrator\\AppData\\Local\\Android\\Sdk\\platform-tools\\adb.exe\" shell am start -n com.bof.mobile/.MainActivity"
    },
    {
      "name": "Backend: Launch Server",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/server",
      "program": "${workspaceFolder}/server/src/index.js",
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Backend: Attach (9229)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
